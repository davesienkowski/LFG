# Dev image for the `web` service (D-12). Runs the Next.js dev server with hot
# reload; source is bind-mounted by docker-compose so edits reflect live.
# No secrets are copied into the image — DATABASE_URL is injected at runtime by
# docker-compose (mitigates T-01-01).
FROM node:22-bookworm

WORKDIR /app

# Install dependencies first for layer caching. Only package manifests are copied;
# the full source is bind-mounted at runtime.
COPY package.json package-lock.json ./
RUN npm install

EXPOSE 3000

# Bind to 0.0.0.0 so the dev server is reachable from the host via the port map.
CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0"]
