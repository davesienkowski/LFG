# Copy to .env.local for host-run tooling (e.g. drizzle-kit). The docker-compose
# `web` service injects its own values at runtime — do NOT commit real secrets.

# Local Docker Postgres (host-run drizzle-kit connects via localhost).
# Inside the compose network the `web` service uses host `db` instead of localhost.
DATABASE_URL="postgres://postgres:password@localhost:5432/lfg"

# Absolute base URL used to build shareable poll links.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Email transport (Phase 4). ALL of these are OPTIONAL (D-02 / MAIL-03): with
# none set, EMAIL_PROVIDER is treated as "none" and the app runs normally,
# surfacing the "Email isn't set up" copy-link fallback instead of sending.
# Canonical names/shape live in src/lib/env.ts — keep this file in sync.
#
# EMAIL_PROVIDER selects the transport branch: "smtp" | "resend" | "none".
#
# D-03 (DMARC trap): EMAIL_FROM must be a sender the active transport is
# authorized for. On smtp.gmail.com, EMAIL_FROM MUST equal SMTP_USER (Google
# auto-aligns SPF/DKIM/DMARC when you send as your own gmail). NEVER put a gmail
# From on a third-party relay — it fails DMARC alignment and spam-folders.
# ---------------------------------------------------------------------------

# --- Local development: Mailpit (captures mail, never delivers) ---
# EMAIL_PROVIDER="smtp"
# SMTP_HOST="mailpit"          # or "localhost" when running outside compose
# SMTP_PORT="1025"
# EMAIL_FROM="dev@localhost"

# --- Production: Gmail SMTP + App Password (D-01 default, free / no-domain) ---
# Requires 2-Step Verification ON, then a generated App Password (Google Account
# → Security → 2-Step Verification → App passwords). Set these in the Vercel
# Production environment — never commit the real App Password.
# EMAIL_PROVIDER="smtp"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="you@gmail.com"          # your Gmail address
# SMTP_PASS="your-16-char-app-password"
# EMAIL_FROM="you@gmail.com"          # D-03: MUST equal SMTP_USER on Gmail
